# Allow build scripts for native modules required by Next.js
# (esbuild + sharp are also listed under pnpm.onlyBuiltDependencies in package.json)

# Skip pnpm 10+'s automatic install-on-script-run. Without this the dev
# container crash-loops: pnpm runs an install before `next dev`, the
# install hits the build-script approval gate, exits non-zero, the
# container restarts, and we loop forever.
verify-deps-before-run=false

# Auto-confirm node_modules purge so CI=true is not required.
confirm-modules-purge=false
